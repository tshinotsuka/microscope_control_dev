{
  "$comment": "C2 freeze -- ADDITIONS to trigger_sync.schema.json (bump to v0.3.0, method A: behavior + sync in one Data Recorder .h5). MERGE STEPS: (1) set schema_version const to '0.3.0'; (2) copy the 3 properties below into the top-level 'properties'; (3) add 'samplerate_hz' and 'recorded_channels' to top-level 'required'. JSON Schema draft 2020-12.",

  "properties": {
    "schema_version": { "const": "0.3.0" },

    "samplerate_hz": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Data Recorder sample rate (root attr 'samplerate' of the .h5)."
    },

    "n_samples": {
      "type": "integer",
      "minimum": 0,
      "description": "samples per channel (longest dataset)."
    },

    "recorded_channels": {
      "type": "array",
      "minItems": 1,
      "description": "every dataset in the Data Recorder .h5, self-describing (sync + behavior).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "ai", "role", "units", "range_v"],
        "properties": {
          "name":  { "type": "string", "minLength": 1,
                     "description": "HDF5 dataset name (== Recorded Name)." },
          "ai":    { "type": "string", "pattern": "^AI[0-9]+$",
                     "description": "physical vDAQ analog-in channel, e.g. 'AI5'." },
          "role":  { "enum": ["injector_trigger", "cycle_clock",
                              "locomotion_speed", "locomotion_direction"],
                     "description": "controlled vocab; extend additively (e.g. 'pupil')." },
          "units": { "const": "V" },
          "range_v": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 2,
            "maxItems": 2,
            "description": "measured [min, max] of the channel."
          }
        }
      }
    }
  },

  "required": ["schema_version", "samplerate_hz", "recorded_channels"]
}
